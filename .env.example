# Copy this to .env for local development.
# On Railway, set these in the Variables tab — do NOT commit your real token.

# Required — your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Optional — where logs are written inside the container (default: ./logs)
# On Railway, consider setting this to /data if you have a volume attached.
LOG_DIR=./logs
